# Supabase — fill these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The single email allowed to sign into the Atelier (email + password).
# Anyone else gets the same generic "email and password don't match" error.
# The actual user is pre-created via SQL — there is no signup flow.
ATELIER_OWNER_EMAIL=owner@example.com

# Public site URL (used for magic link redirects). Set to deployed URL in Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
